{
  "name": "@acme/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/apps/api/src/main.js",
    "worker:domains-dns": "node dist/apps/api/src/domains/domain-dns.worker.js",
    "worker:domains-ssl": "node dist/apps/api/src/domains/domain-ssl.worker.js",
    "lint": "tsc --project tsconfig.json --noEmit",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test:catalog": "node --test dist/apps/api/src/catalog/catalog-categories.test.js",
    "test:tenant-resolution": "node --test dist/apps/api/src/domains/tenant-resolution.test.js",
    "test:domains": "node --test dist/apps/api/src/domains/tenant-resolution.test.js dist/apps/api/src/domains/domain-registration.test.js dist/apps/api/src/domains/domain-dns-verification.test.js dist/apps/api/src/domains/domain-ssl-provisioning.test.js"
  },
  "dependencies": {
    "@acme/config": "workspace:*",
    "@acme/database": "workspace:*",
    "@acme/queue": "workspace:*",
    "@acme/types": "workspace:*",
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.3",
    "@prisma/client": "^6.10.1",
    "bullmq": "^5.56.7",
    "ioredis": "^5.6.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.1.3",
    "@types/node": "^24.0.10",
    "prisma": "^6.10.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
