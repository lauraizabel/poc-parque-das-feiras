{
  "name": "saas-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "postinstall": "pnpm db:generate",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "ci:lint": "pnpm lint",
    "ci:typecheck": "pnpm typecheck",
    "ci:build:test": "pnpm --filter @acme/types build && pnpm --filter @acme/config build && pnpm --filter @acme/database build && pnpm --filter @acme/queue build && pnpm --filter @acme/api build",
    "ci:test": "pnpm ci:build:test && pnpm --filter @acme/queue test && pnpm --filter @acme/api test:ci",
    "ci:migrations": "pnpm db:generate && pnpm db:migrate:deploy && pnpm db:status",
    "format": "prettier --write .",
    "db:generate": "pnpm --filter @acme/database db:generate",
    "db:migrate": "pnpm --filter @acme/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @acme/database db:migrate:deploy",
    "db:status": "pnpm --filter @acme/database db:status",
    "db:seed": "pnpm --filter @acme/database db:seed",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "turbo": "^2.0.12",
    "typescript": "^5.9.2"
  }
}
