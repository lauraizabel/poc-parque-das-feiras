generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  SUSPENDED
}

enum PlatformRole {
  PLATFORM_ADMIN
  CUSTOMER
}

enum StoreMemberRole {
  STORE_OWNER
  STORE_MANAGER
  STORE_SUPPORT
}

enum StoreDomainType {
  CUSTOM_DOMAIN
}

enum DomainStatus {
  PENDING
  AWAITING_DNS
  VERIFYING
  SSL_PENDING
  ACTIVE
  ERROR
  REMOVED
}

enum PaymentProvider {
  STRIPE_CONNECT
  PAGARME
  MERCADO_PAGO
  ASAAS
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  fullName         String?
  passwordHash     String
  refreshTokenHash String?
  platformRole     PlatformRole  @default(CUSTOMER)
  ownedStores      Store[]       @relation("StoreOwner")
  storeMembers     StoreMember[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Store {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  defaultSubdomain  String            @unique
  ownerId           String
  supportEmail      String?
  currencyCode      String            @default("BRL")
  locale            String            @default("pt-BR")
  status            StoreStatus       @default(TRIALING)
  owner             User              @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  storeMembers      StoreMember[]
  domains           StoreDomain[]
  paymentAccounts   PaymentAccount[]
  assets            Asset[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([ownerId])
}

model StoreMember {
  id        String          @id @default(cuid())
  userId    String
  storeId   String
  role      StoreMemberRole @default(STORE_SUPPORT)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userId, storeId])
  @@index([storeId])
}

model StoreDomain {
  id                 String          @id @default(cuid())
  host               String          @unique
  type               StoreDomainType @default(CUSTOM_DOMAIN)
  status             DomainStatus    @default(PENDING)
  dnsTargetValue     String?
  dnsConfiguredValue String?
  dnsLastCheckedAt   DateTime?
  dnsVerifiedAt      DateTime?
  dnsErrorMessage    String?
  sslProvisioningId  String?
  sslLastCheckedAt   DateTime?
  sslIssuedAt        DateTime?
  sslErrorMessage    String?
  activatedAt        DateTime?
  removedAt          DateTime?
  storeId            String
  store              Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([storeId, type])
  @@index([storeId])
  @@index([status])
  @@map("Domain")
}

model PaymentAccount {
  id                 String          @id @default(cuid())
  provider           PaymentProvider
  externalAccountId  String
  externalCustomerId String?
  storeId            String
  store              Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([provider, externalAccountId])
  @@index([storeId])
}

model Asset {
  id         String   @id @default(cuid())
  storeId    String
  key        String   @unique
  bucket     String
  mimeType   String
  sizeBytes  Int
  publicUrl  String?
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([storeId])
}
