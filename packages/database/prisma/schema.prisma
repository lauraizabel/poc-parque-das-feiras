generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  SUSPENDED
}

enum PlatformRole {
  PLATFORM_ADMIN
  CUSTOMER
}

enum StoreMemberRole {
  STORE_OWNER
  STORE_MANAGER
  STORE_SUPPORT
}

enum StoreDomainType {
  CUSTOM_DOMAIN
}

enum DomainStatus {
  PENDING
  AWAITING_DNS
  VERIFYING
  SSL_PENDING
  ACTIVE
  ERROR
  REMOVED
}

enum PaymentProvider {
  STRIPE_CONNECT
  PAGARME
  MERCADO_PAGO
  ASAAS
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  fullName         String?
  passwordHash     String
  refreshTokenHash String?
  platformRole     PlatformRole  @default(CUSTOMER)
  ownedStores      Store[]       @relation("StoreOwner")
  storeMembers     StoreMember[]
  carts            Cart[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Store {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  defaultSubdomain  String            @unique
  ownerId           String
  supportEmail      String?
  currencyCode      String            @default("BRL")
  locale            String            @default("pt-BR")
  status            StoreStatus       @default(TRIALING)
  owner             User              @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  storeMembers      StoreMember[]
  domains           StoreDomain[]
  paymentAccounts   PaymentAccount[]
  assets            Asset[]
  categories        Category[]
  products          Product[]
  carts             Cart[]
  cartItems         CartItem[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([ownerId])
}

model StoreMember {
  id        String          @id @default(cuid())
  userId    String
  storeId   String
  role      StoreMemberRole @default(STORE_SUPPORT)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userId, storeId])
  @@index([storeId])
}

model StoreDomain {
  id                 String          @id @default(cuid())
  host               String          @unique
  type               StoreDomainType @default(CUSTOM_DOMAIN)
  status             DomainStatus    @default(PENDING)
  dnsTargetValue     String?
  dnsConfiguredValue String?
  dnsLastCheckedAt   DateTime?
  dnsVerifiedAt      DateTime?
  dnsErrorMessage    String?
  sslProvisioningId  String?
  sslProvisioningMetadata String?
  sslLastCheckedAt   DateTime?
  sslIssuedAt        DateTime?
  sslErrorMessage    String?
  activatedAt        DateTime?
  removedAt          DateTime?
  storeId            String
  store              Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([storeId, type])
  @@index([storeId])
  @@index([status])
  @@map("Domain")
}

model PaymentAccount {
  id                 String          @id @default(cuid())
  provider           PaymentProvider
  externalAccountId  String
  externalCustomerId String?
  storeId            String
  store              Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([provider, externalAccountId])
  @@index([storeId])
}

model Asset {
  id         String   @id @default(cuid())
  storeId    String
  key        String   @unique
  bucket     String
  mimeType   String
  sizeBytes  Int
  publicUrl  String?
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productImages ProductImage[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([storeId])
}

model Category {
  id          String         @id @default(cuid())
  storeId     String
  name        String
  slug        String
  description String?
  status      CategoryStatus @default(ACTIVE)
  sortOrder   Int            @default(0)
  store       Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products    Product[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([storeId, slug])
  @@index([storeId, status])
  @@index([storeId, sortOrder])
}

model Product {
  id               String         @id @default(cuid())
  storeId          String
  categoryId       String?
  name             String
  slug             String
  description      String?
  sku              String?
  priceCents       Int
  compareAtCents   Int?
  currencyCode     String         @default("BRL")
  stockQuantity    Int            @default(0)
  status           ProductStatus  @default(DRAFT)
  isFeatured       Boolean        @default(false)
  store            Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category         Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images           ProductImage[]
  variants         ProductVariant[]
  cartItems        CartItem[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([id, storeId])
  @@unique([storeId, slug])
  @@unique([storeId, sku])
  @@index([storeId, status])
  @@index([storeId, categoryId])
}

model Cart {
  id            String      @id @default(cuid())
  storeId       String
  userId        String?
  sessionId     String?
  customerEmail String?
  status        CartStatus  @default(ACTIVE)
  currencyCode  String      @default("BRL")
  expiresAt     DateTime?
  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items         CartItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([id, storeId])
  @@index([storeId, status])
  @@index([storeId, sessionId, status])
  @@index([storeId, userId, status])
  @@index([storeId, customerEmail, status])
}

model CartItem {
  id               String   @id @default(cuid())
  cartId           String
  storeId          String
  productId        String
  quantity         Int      @default(1)
  productName      String
  productSlug      String
  unitPriceCents   Int
  compareAtCents   Int?
  currencyCode     String   @default("BRL")
  cart             Cart     @relation(fields: [cartId, storeId], references: [id, storeId], onDelete: Cascade)
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId, storeId], references: [id, storeId], onDelete: Restrict)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId, storeId])
  @@index([storeId, productId])
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  assetId     String?
  altText     String?
  imageUrl    String
  sortOrder   Int      @default(0)
  isPrimary   Boolean  @default(false)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  asset       Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId, sortOrder])
  @@index([productId, isPrimary])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  name          String
  sku           String?
  priceCents    Int?
  stockQuantity Int      @default(0)
  sortOrder     Int      @default(0)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([productId, sku])
  @@index([productId, sortOrder])
}
