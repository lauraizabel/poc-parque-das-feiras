generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  SUSPENDED
}

enum PlatformRole {
  PLATFORM_ADMIN
  CUSTOMER
}

enum StoreMemberRole {
  STORE_OWNER
  STORE_MANAGER
  STORE_SUPPORT
}

enum StoreDomainType {
  CUSTOM_DOMAIN
}

enum DomainStatus {
  PENDING
  AWAITING_DNS
  VERIFYING
  SSL_PENDING
  ACTIVE
  ERROR
  REMOVED
}

enum PaymentProvider {
  STRIPE_CONNECT
  PAGARME
  MERCADO_PAGO
  ASAAS
}

enum CustomerStatus {
  ACTIVE
  ARCHIVED
}

enum PaymentStatus {
  CREATED
  PENDING
  AUTHORIZED
  APPROVED
  FAILED
  CANCELED
  EXPIRED
  REFUNDED
}

enum PaymentTransactionKind {
  INTENT
  AUTHORIZATION
  CAPTURE
  CANCELLATION
  REFUND
  WEBHOOK
}

enum PaymentTransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

enum PaymentWebhookStatus {
  RECEIVED
  DUPLICATE
  PROCESSING
  PROCESSED
  FAILED
}

enum StatusTransitionEntityType {
  PAYMENT
  ORDER
}

enum OrderStatus {
  CREATED
  WAITING_PAYMENT
  PAYMENT_APPROVED
  PAYMENT_FAILED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED
}

enum ShippingMethodType {
  FIXED_PRICE
  LOCAL_PICKUP
}

enum ShippingMethodStatus {
  ACTIVE
  INACTIVE
}

enum ShipmentStatus {
  PENDING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELED
  RETURNED
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
}

enum AuthFlowTokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum AuthFlowAuditAction {
  EMAIL_VERIFICATION_REQUESTED
  EMAIL_VERIFICATION_CONFIRMED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
}

enum AuditLogChannel {
  HTTP_API
  JOB
  SYSTEM
  WEBHOOK
}

enum NotificationChannel {
  EMAIL
}

enum NotificationStatus {
  PENDING
  QUEUED
  DELIVERED
  FAILED
  CANCELED
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  fullName         String?
  passwordHash     String
  refreshTokenHash String?
  emailVerifiedAt  DateTime?
  platformRole     PlatformRole  @default(CUSTOMER)
  ownedStores      Store[]       @relation("StoreOwner")
  storeMembers     StoreMember[]
  sentStoreInvites StoreMemberInvite[]
  carts            Cart[]
  authFlowTokens   AuthFlowToken[]
  authFlowAudits   AuthFlowAudit[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model AuthFlowToken {
  id            String               @id @default(cuid())
  userId        String
  purpose       AuthFlowTokenPurpose
  tokenHash     String               @unique
  expiresAt     DateTime
  consumedAt    DateTime?
  invalidatedAt DateTime?
  lastSentAt    DateTime             @default(now())
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditEvents   AuthFlowAudit[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([userId, purpose, createdAt])
  @@index([purpose, expiresAt])
}

model AuthFlowAudit {
  id          String               @id @default(cuid())
  userId      String
  tokenId     String?
  action      AuthFlowAuditAction
  purpose     AuthFlowTokenPurpose
  success     Boolean              @default(true)
  metadata    String?
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       AuthFlowToken?       @relation(fields: [tokenId], references: [id], onDelete: SetNull)
  createdAt   DateTime             @default(now())

  @@index([userId, action, createdAt])
  @@index([purpose, createdAt])
}

model Store {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  defaultSubdomain  String            @unique
  ownerId           String
  supportEmail      String?
  currencyCode      String            @default("BRL")
  locale            String            @default("pt-BR")
  status            StoreStatus       @default(TRIALING)
  owner             User              @relation("StoreOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  storeMembers      StoreMember[]
  memberInvites     StoreMemberInvite[]
  theme             StoreTheme?
  domains           StoreDomain[]
  paymentAccounts   PaymentAccount[]
  customers         Customer[]
  payments          Payment[]
  paymentTransactions PaymentTransaction[]
  paymentWebhookEvents PaymentWebhookEvent[]
  statusTransitionAudits StatusTransitionAudit[]
  shippingMethods   ShippingMethod[]
  shipments         Shipment[]
  orders            Order[]
  orderItems        OrderItem[]
  assets            Asset[]
  categories        Category[]
  products          Product[]
  carts             Cart[]
  cartItems         CartItem[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([ownerId])
}

model AuditLog {
  id             String          @id @default(cuid())
  userId         String?
  storeId        String?
  action         String
  channel        AuditLogChannel
  entityType     String?
  entityId       String?
  payloadSummary String?
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  store          Store?          @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdAt      DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([storeId, createdAt])
  @@index([action, createdAt])
  @@index([channel, createdAt])
  @@index([entityType, entityId, createdAt])
}

model Notification {
  id             String             @id @default(cuid())
  userId         String?
  storeId        String?
  channel        NotificationChannel
  status         NotificationStatus @default(PENDING)
  recipient      String
  subject        String?
  templateKey    String?
  provider       String?
  payloadSummary String?
  queuedAt       DateTime?
  deliveredAt    DateTime?
  failedAt       DateTime?
  failureMessage String?
  user           User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  store          Store?             @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([userId, createdAt])
  @@index([storeId, createdAt])
  @@index([channel, status, createdAt])
  @@index([recipient, createdAt])
  @@index([templateKey, createdAt])
}

model StoreTheme {
  id                 String   @id @default(cuid())
  storeId            String   @unique
  primaryColor       String   @default("#c45c2c")
  accentColor        String   @default("#8f3610")
  surfaceColor       String   @default("#f5f1e8")
  logoUrl            String?
  bannerUrl          String?
  heroTitle          String?
  heroSubtitle       String?
  announcementText   String?
  store              Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([storeId])
}

model StoreMember {
  id        String          @id @default(cuid())
  userId    String
  storeId   String
  role      StoreMemberRole @default(STORE_SUPPORT)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userId, storeId])
  @@index([storeId])
}

model StoreMemberInvite {
  id           String          @id @default(cuid())
  storeId       String
  invitedEmail  String
  role          StoreMemberRole @default(STORE_SUPPORT)
  invitedByUserId String
  store         Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  invitedByUser User            @relation(fields: [invitedByUserId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([storeId, invitedEmail])
  @@index([invitedByUserId])
}

model StoreDomain {
  id                 String          @id @default(cuid())
  host               String          @unique
  type               StoreDomainType @default(CUSTOM_DOMAIN)
  status             DomainStatus    @default(PENDING)
  dnsTargetValue     String?
  dnsConfiguredValue String?
  dnsLastCheckedAt   DateTime?
  dnsVerifiedAt      DateTime?
  dnsErrorMessage    String?
  sslProvisioningId  String?
  sslProvisioningMetadata String?
  sslLastCheckedAt   DateTime?
  sslIssuedAt        DateTime?
  sslErrorMessage    String?
  activatedAt        DateTime?
  removedAt          DateTime?
  storeId            String
  store              Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([storeId, type])
  @@index([storeId])
  @@index([status])
  @@map("Domain")
}

model PaymentAccount {
  id                 String          @id @default(cuid())
  provider           PaymentProvider
  externalAccountId  String
  externalCustomerId String?
  storeId            String
  store              Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([provider, externalAccountId])
  @@index([storeId])
}

model Customer {
  id             String         @id @default(cuid())
  storeId        String
  email          String
  fullName       String?
  phoneNumber    String?
  documentNumber String?
  notes          String?
  status         CustomerStatus @default(ACTIVE)
  store          Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  carts          Cart[]
  payments       Payment[]
  orders         Order[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([id, storeId])
  @@unique([storeId, email])
  @@index([storeId, status])
}

model Asset {
  id         String   @id @default(cuid())
  storeId    String
  key        String   @unique
  bucket     String
  mimeType   String
  sizeBytes  Int
  publicUrl  String?
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productImages ProductImage[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([storeId])
}

model Category {
  id          String         @id @default(cuid())
  storeId     String
  name        String
  slug        String
  description String?
  status      CategoryStatus @default(ACTIVE)
  sortOrder   Int            @default(0)
  store       Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products    Product[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([storeId, slug])
  @@index([storeId, status])
  @@index([storeId, sortOrder])
}

model Product {
  id               String         @id @default(cuid())
  storeId          String
  categoryId       String?
  name             String
  slug             String
  description      String?
  sku              String?
  priceCents       Int
  compareAtCents   Int?
  currencyCode     String         @default("BRL")
  stockQuantity    Int            @default(0)
  status           ProductStatus  @default(DRAFT)
  isFeatured       Boolean        @default(false)
  store            Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category         Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  images           ProductImage[]
  variants         ProductVariant[]
  cartItems        CartItem[]
  orderItems       OrderItem[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([id, storeId])
  @@unique([storeId, slug])
  @@unique([storeId, sku])
  @@index([storeId, status])
  @@index([storeId, categoryId])
}

model Cart {
  id            String      @id @default(cuid())
  storeId       String
  userId        String?
  customerId    String?
  sessionId     String?
  customerEmail String?
  status        CartStatus  @default(ACTIVE)
  currencyCode  String      @default("BRL")
  expiresAt     DateTime?
  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  customer      Customer?   @relation(fields: [customerId, storeId], references: [id, storeId], onDelete: SetNull)
  items         CartItem[]
  payments      Payment[]
  orders        Order[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([id, storeId])
  @@index([storeId, status])
  @@index([storeId, customerId, status])
  @@index([storeId, sessionId, status])
  @@index([storeId, userId, status])
  @@index([storeId, customerEmail, status])
}

model CartItem {
  id               String   @id @default(cuid())
  cartId           String
  storeId          String
  productId        String
  quantity         Int      @default(1)
  productName      String
  productSlug      String
  unitPriceCents   Int
  compareAtCents   Int?
  currencyCode     String   @default("BRL")
  cart             Cart     @relation(fields: [cartId, storeId], references: [id, storeId], onDelete: Cascade)
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId, storeId], references: [id, storeId], onDelete: Restrict)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId, storeId])
  @@index([storeId, productId])
}

model Payment {
  id                    String         @id @default(cuid())
  storeId               String
  cartId                String
  customerId            String?
  provider              PaymentProvider
  status                PaymentStatus  @default(CREATED)
  currencyCode          String         @default("BRL")
  amountCents           Int
  attemptCount          Int            @default(0)
  externalPaymentId     String?
  externalReference     String?
  providerPayload       String?
  metadata              String?
  failureCode           String?
  failureMessage        String?
  expiresAt             DateTime?
  paidAt                DateTime?
  store                 Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cart                  Cart           @relation(fields: [cartId, storeId], references: [id, storeId], onDelete: Restrict)
  customer              Customer?      @relation(fields: [customerId, storeId], references: [id, storeId], onDelete: SetNull)
  transactions          PaymentTransaction[]
  orders                Order[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@unique([id, storeId])
  @@index([storeId, status])
  @@index([storeId, cartId])
  @@index([storeId, customerId])
  @@index([provider, externalPaymentId])
}

model PaymentTransaction {
  id                    String                   @id @default(cuid())
  paymentId             String
  storeId               String
  provider              PaymentProvider
  kind                  PaymentTransactionKind
  status                PaymentTransactionStatus @default(PENDING)
  idempotencyKey        String?
  externalTransactionId String?
  requestPayload        String?
  responsePayload       String?
  errorCode             String?
  errorMessage          String?
  occurredAt            DateTime?
  store                 Store                    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  payment               Payment                  @relation(fields: [paymentId, storeId], references: [id, storeId], onDelete: Cascade)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([storeId, paymentId])
  @@index([paymentId, kind, status])
  @@index([provider, externalTransactionId])
  @@index([paymentId, idempotencyKey])
}

model PaymentWebhookEvent {
  id               String               @id @default(cuid())
  provider         PaymentProvider
  status           PaymentWebhookStatus @default(RECEIVED)
  externalEventId  String
  eventType        String
  paymentId        String?
  orderId          String?
  storeId          String?
  idempotencyKey   String?
  signature        String?
  requestHeaders   String?
  payload          String
  userAgent        String?
  sourceIp         String?
  livemode         Boolean?
  receivedAt       DateTime             @default(now())
  processedAt      DateTime?
  failureMessage   String?
  store            Store?               @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([provider, externalEventId])
  @@index([provider, status])
  @@index([storeId, status])
  @@index([paymentId])
  @@index([orderId])
  @@index([provider, idempotencyKey])
}

model StatusTransitionAudit {
  id          String                     @id @default(cuid())
  entityType  StatusTransitionEntityType
  entityId    String
  storeId     String?
  fromStatus  String?
  toStatus    String
  allowed     Boolean                    @default(true)
  reason      String?
  source      String
  actorType   String?
  actorId     String?
  metadata    String?
  store       Store?                     @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdAt   DateTime                   @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([storeId, createdAt])
  @@index([allowed, createdAt])
}

model ShippingMethod {
  id                String               @id @default(cuid())
  storeId           String
  name              String
  description       String?
  type              ShippingMethodType   @default(FIXED_PRICE)
  status            ShippingMethodStatus @default(ACTIVE)
  priceCents        Int                  @default(0)
  estimatedDaysMin  Int?
  estimatedDaysMax  Int?
  minimumOrderCents Int?
  maximumOrderCents Int?
  sortOrder         Int                  @default(0)
  isDefault         Boolean              @default(false)
  store             Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders            Order[]
  shipments         Shipment[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([storeId, status, sortOrder])
  @@index([storeId, type])
}

model Shipment {
  id                String         @id @default(cuid())
  storeId           String
  orderId           String         @unique
  shippingMethodId  String?
  status            ShipmentStatus @default(PENDING)
  shippingMethodName String
  carrierName       String?
  serviceName       String?
  trackingCode      String?
  trackingUrl       String?
  labelUrl          String?
  priceCents        Int            @default(0)
  estimatedDaysMin  Int?
  estimatedDaysMax  Int?
  postedAt          DateTime?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  canceledAt        DateTime?
  notes             String?
  store             Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order             Order          @relation(fields: [orderId, storeId], references: [id, storeId], onDelete: Cascade)
  shippingMethod    ShippingMethod? @relation(fields: [shippingMethodId], references: [id], onDelete: SetNull)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([orderId, storeId])
  @@index([storeId, status])
  @@index([shippingMethodId])
}

model Order {
  id                       String      @id @default(cuid())
  storeId                  String
  cartId                   String?
  customerId               String?
  paymentId                String?
  shippingMethodId         String?
  publicAccessTokenHash    String?
  status                   OrderStatus @default(CREATED)
  currencyCode             String      @default("BRL")
  subtotalCents            Int
  shippingCents            Int         @default(0)
  discountCents            Int         @default(0)
  totalCents               Int
  customerEmail            String
  customerFullName         String?
  customerPhoneNumber      String?
  shippingRecipientName    String?
  shippingPhoneNumber      String?
  shippingPostalCode       String?
  shippingState            String?
  shippingCity             String?
  shippingDistrict         String?
  shippingStreet           String?
  shippingNumber           String?
  shippingComplement       String?
  billingRecipientName     String?
  billingPhoneNumber       String?
  billingPostalCode        String?
  billingState             String?
  billingCity              String?
  billingDistrict          String?
  billingStreet            String?
  billingNumber            String?
  billingComplement        String?
  notes                    String?
  statusUpdatedAt          DateTime    @default(now())
  approvedAt               DateTime?
  canceledAt               DateTime?
  refundedAt               DateTime?
  shippedAt                DateTime?
  deliveredAt              DateTime?
  store                    Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cart                     Cart?       @relation(fields: [cartId, storeId], references: [id, storeId], onDelete: SetNull)
  customer                 Customer?   @relation(fields: [customerId, storeId], references: [id, storeId], onDelete: SetNull)
  payment                  Payment?    @relation(fields: [paymentId, storeId], references: [id, storeId], onDelete: SetNull)
  shippingMethod           ShippingMethod? @relation(fields: [shippingMethodId], references: [id], onDelete: SetNull)
  shipment                 Shipment?
  items                    OrderItem[]
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  @@unique([id, storeId])
  @@index([storeId, status])
  @@index([storeId, customerId])
  @@index([storeId, paymentId])
  @@index([storeId, cartId])
  @@index([storeId, shippingMethodId])
}

model OrderItem {
  id               String   @id @default(cuid())
  orderId          String
  storeId          String
  productId        String?
  productName      String
  productSlug      String
  quantity         Int
  unitPriceCents   Int
  compareAtCents   Int?
  discountCents    Int      @default(0)
  totalCents       Int
  currencyCode     String   @default("BRL")
  sku              String?
  categoryName     String?
  categorySlug     String?
  order            Order    @relation(fields: [orderId, storeId], references: [id, storeId], onDelete: Cascade)
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product          Product? @relation(fields: [productId, storeId], references: [id, storeId], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([orderId, storeId])
  @@index([storeId, productId])
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  assetId     String?
  altText     String?
  imageUrl    String
  sortOrder   Int      @default(0)
  isPrimary   Boolean  @default(false)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  asset       Asset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId, sortOrder])
  @@index([productId, isPrimary])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  name          String
  sku           String?
  priceCents    Int?
  stockQuantity Int      @default(0)
  sortOrder     Int      @default(0)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([productId, sku])
  @@index([productId, sortOrder])
}
