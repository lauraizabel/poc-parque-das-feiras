generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StoreStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  SUSPENDED
}

enum PlatformRole {
  PLATFORM_ADMIN
  CUSTOMER
}

enum StoreMemberRole {
  STORE_OWNER
  STORE_MANAGER
  STORE_SUPPORT
}

enum DomainStatus {
  PENDING
  VERIFIED
  FAILED
}

enum PaymentProvider {
  STRIPE_CONNECT
  PAGARME
  MERCADO_PAGO
  ASAAS
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  fullName      String?
  platformRole  PlatformRole  @default(CUSTOMER)
  storeMembers  StoreMember[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Store {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  status            StoreStatus       @default(TRIALING)
  storeMembers      StoreMember[]
  domains           Domain[]
  paymentAccounts   PaymentAccount[]
  assets            Asset[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model StoreMember {
  id        String          @id @default(cuid())
  userId    String
  storeId   String
  role      StoreMemberRole @default(STORE_SUPPORT)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([userId, storeId])
  @@index([storeId])
}

model Domain {
  id         String       @id @default(cuid())
  hostname   String       @unique
  status     DomainStatus @default(PENDING)
  verifiedAt DateTime?
  storeId    String
  store      Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([storeId])
}

model PaymentAccount {
  id                 String          @id @default(cuid())
  provider           PaymentProvider
  externalAccountId  String
  externalCustomerId String?
  storeId            String
  store              Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([provider, externalAccountId])
  @@index([storeId])
}

model Asset {
  id         String   @id @default(cuid())
  storeId    String
  key        String   @unique
  bucket     String
  mimeType   String
  sizeBytes  Int
  publicUrl  String?
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([storeId])
}
